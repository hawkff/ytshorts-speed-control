{
  "tasks": {
    "test": "deno test",
    "check": "deno fmt --check && deno lint && deno test"
  },
  "fmt": {
    "include": ["lib/", "src/", "tests/", "deno.json"],
    "exclude": ["icons/", ".agents/", "**/._*"]
  },
  "lint": {
    "include": ["lib/", "src/", "tests/"],
    "exclude": ["icons/", ".agents/", "**/._*"],
    "rules": {
      "tags": ["recommended"]
    }
  },
  "test": {
    "include": ["tests/"],
    "exclude": ["**/._*"]
  },
  "imports": {
    "@std/assert": "jsr:@std/assert@1"
  }
}
